# ┌──────────────────────────────────────────────────────────────┐
# │  CSW POV Template — Environment Configuration              │
# │                                                            │
# │  Copy this file to .env and fill in your cluster details:  │
# │    cp .env.example .env                                    │
# │                                                            │
# │  Generate API keys in the CSW UI:                          │
# │    User Menu → API Keys → Create API Key                   │
# │                                                            │
# │  Required capabilities: sensor_management,                 │
# │    flow_inventory_query, app_policy_management             │
# └──────────────────────────────────────────────────────────────┘

# Cluster base URL (no trailing slash, no path)
CSW_API_URL=https://your-cluster.tetrationcloud.com

# API key (hex string from CSW UI)
CSW_API_KEY=your_api_key_here

# HMAC signing secret (paired with API key)
CSW_API_SECRET=your_api_secret_here

# Root scope name (auto-detected by most scripts; set explicitly if needed)
# CSW_ROOT_SCOPE=your-root-scope

# Set to "false" if you see CERTIFICATE_VERIFY_FAILED
# (corporate TLS proxy / macOS Python certs issue).
# Proper fix: trust your org root CA or run Python's "Install Certificates.command".
CSW_VERIFY_SSL=false
